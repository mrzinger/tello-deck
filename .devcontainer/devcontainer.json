// README at: https://github.com/devcontainers/templates/tree/main/src/cpp
{
	"name": "C++",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
	"remoteUser": "root",
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y flatpak flatpak-builder desktop-file-utils appstream && flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo && flatpak install -y flathub org.freedesktop.Sdk//24.08 org.freedesktop.Platform//24.08",
	"runArgs": [
		"--privileged"
		]
}
